{
    "name": "liberu-cms/cms-blocks",
    "description": "Block system and page-builder rendering for Liberu CMS: a registry of block types and a recursive, XSS-safe renderer.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": "^8.5",
        "liberu-cms/cms-contracts": "*",
        "liberu-cms/cms-core": "*",
        "illuminate/support": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Liberu\\Cms\\Blocks\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Liberu\\Cms\\Blocks\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Liberu\\Cms\\Blocks\\BlocksServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
