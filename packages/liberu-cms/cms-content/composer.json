{
    "name": "liberu-cms/cms-content",
    "description": "Content foundation for Liberu CMS: editorial workflow and versioning shared by every content module.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": "^8.5",
        "liberu-cms/cms-contracts": "*",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Liberu\\Cms\\Content\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Liberu\\Cms\\Content\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Liberu\\Cms\\Content\\ContentServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
