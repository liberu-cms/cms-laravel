{
    "name": "liberu-cms/cms-content-types",
    "description": "Custom content types for Liberu CMS: JSON field schemas and validated content entries with workflow and versioning.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": "^8.5",
        "liberu-cms/cms-contracts": "*",
        "liberu-cms/cms-core": "*",
        "liberu-cms/cms-content": "*",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Liberu\\Cms\\ContentTypes\\": "src/",
            "Liberu\\Cms\\ContentTypes\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Liberu\\Cms\\ContentTypes\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Liberu\\Cms\\ContentTypes\\ContentTypesServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
