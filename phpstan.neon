includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: max
    paths:
        - packages/liberu-cms/cms-content/src
        - packages/liberu-cms/cms-content-types/src
        - packages/liberu-cms/cms-contracts/src
        - packages/liberu-cms/cms-core/src
        - packages/liberu-cms/cms-hello/src
        - packages/liberu-cms/cms-media/src
        - packages/liberu-cms/cms-pages/src
        - packages/liberu-cms/cms-posts/src
        - packages/liberu-cms/cms-themes/src
        - packages/liberu-cms/cms-users/src
        - tests/Fixtures
    treatPhpDocTypesAsCertain: false
